# ========== 基础配置 ==========
ENV=development
DEBUG=true
PROJECT_NAME=猫咪民宿智能排班系统
PROJECT_VERSION=1.0.0

# ========== 服务配置 ==========
HOST=0.0.0.0
PORT=8000
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","http://localhost:8081"]

# ========== 数据库配置 ==========
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=cat_hotel

# ========== Redis配置 ==========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ========== JWT配置 ==========
JWT_SECRET_KEY=your-secret-key-change-in-production-please-0123456789
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# ========== 备份配置 ==========
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30
BACKUP_DIR=/backup
BACKUP_HOUR=2
BACKUP_MINUTE=0

# ========== 日志配置 ==========
LOG_LEVEL=INFO
LOG_FILE_PATH=/app/logs/app.log

# ========== 限流配置 ==========
RATE_LIMIT_PER_SECOND=100
RATE_LIMIT_PER_MINUTE=1000
